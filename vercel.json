{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @brain/api exec prisma generate && pnpm -C apps/web build",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30,
      "includeFiles": "apps/api/**,packages/**,infra/**,node_modules/.prisma/**,node_modules/@prisma/client/**"
    }
  },
  "rewrites": [
    { "source": "/api/v1/:path*", "destination": "/api/v1/catchall" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
